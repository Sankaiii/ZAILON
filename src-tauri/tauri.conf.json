{
  "productName": "ZAILON",
  "version": "1.0.0",
  "identifier": "com.souanpt.zailon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZAILON",
        "width": 960,
        "height": 580,
        "minWidth": 854,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "visible": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Universal Mod Launcher",
    "longDescription": "ZAILON is a local-first universal mod launcher.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": false
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  }
}
